{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "claude",
          "cmd": "claude",
          "args": [
            "--resume",
            { "validator": "^[a-f0-9\\-]{36}$" }
          ]
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "core:window:allow-start-dragging"
  ]
}
